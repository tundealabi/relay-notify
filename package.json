{
  "name": "relay-notify",
  "private": true,
  "version": "0.1.0",
  "description": "Async multi-channel notification engine",
  "scripts": {
    "build": "pnpm --filter @relay/shared build && pnpm -r --filter '!@relay/shared' build",
    "dev": "pnpm --filter @relay/shared build && pnpm -r --parallel dev",
    "dev:server": "pnpm --filter @relay/server dev",
    "dev:web": "pnpm --filter @relay/web dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.12.1",
  "devDependencies": {
    "husky": "^9.1.7",
    "prettier": "^3.8.4"
  }
}
