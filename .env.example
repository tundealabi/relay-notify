# Relay — Server environment variables
# Copy to apps/server/.env for local development

# Server
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173

# Demo mode: allow unauthenticated GET requests for dashboard (development only)
DEMO_MODE=true

# Database (matches docker-compose.yml defaults)
DATABASE_URL=postgresql://relay:relay@localhost:5432/relay

# Redis (matches docker-compose.yml defaults)
REDIS_URL=redis://localhost:6379

# Idempotency
IDEMPOTENCY_TTL_SECONDS=86400

# Mock provider behavior (percentages should sum to 100)
MOCK_SUCCESS_RATE=70
MOCK_ERROR_RATE=20
MOCK_SLOW_RATE=10
MOCK_SLOW_DELAY_MS=15000

# Timeouts & retries
PROVIDER_TIMEOUT_MS=10000
NOTIFICATION_MAX_ATTEMPTS=5
NOTIFICATION_BACKOFF_MS=1000
WEBHOOK_MAX_ATTEMPTS=3

# Logging
LOG_LEVEL=info
